# Copy to .env and fill in your values
# NEVER commit .env to GitHub

ANTHROPIC_API_KEY=your_anthropic_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Path to ai-infra-monitor's metrics file (adjust if installed elsewhere)
METRICS_FILE=../ai-infra-monitor/data/metrics.json

# On-Call Assistant webhook (set to route alerts through On-Call instead of direct Telegram)
# If unset, alerts fall back to direct Telegram
ONCALL_WEBHOOK_URL=https://oncall.ado-runner.com/webhooks/infra-monitor
ONCALL_WEBHOOK_SECRET=your_shared_webhook_secret_here
